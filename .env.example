# Telegram
BOT_TOKEN=YourBotToken
BOT_MODE=polling
# webhook rejimi uchun (production):
WEBHOOK_URL=https://sizning-domeningiz.uz/webhook
WEBHOOK_SECRET=super-secret-random-string

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/playstation_rental?schema=public"

# Server
PORT=3000
NODE_ENV=development

# Admin (birinchi super-admin telegram ID, vergul bilan bir nechta bo'lishi mumkin)
ADMIN_TELEGRAM_IDS=111111111,222222222

# Super Admin — Factory Reset va eng xavfli amallar (bo'sh = faqat birinchi ADMIN_TELEGRAM_IDS)
SUPER_ADMIN_TELEGRAM_IDS=111111111

# Biznes sozlamalari
RETURN_REMINDER_HOURS_BEFORE=2
COURIER_RESPONSE_TIMEOUT_MINUTES=10
DEFAULT_COMMISSION_PERCENT=0

# Anti-spam / Rate limit
# 2 soniya ichida 3+ so'rov → 60 soniya blok
RATE_LIMIT_WINDOW_MS=2000
RATE_LIMIT_MAX_REQUESTS=3
RATE_LIMIT_BLOCK_MS=60000
