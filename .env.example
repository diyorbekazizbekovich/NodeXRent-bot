# -----------------------------------------------------------------------------
# NodeXRent / PlayStation Rental Bot — production environment template
# Copy to .env on the VPS and fill real values. NEVER commit .env.
# -----------------------------------------------------------------------------

# Telegram
BOT_TOKEN=123456:ABC-REPLACE_WITH_REAL_TOKEN
# polling = long polling (simplest on VPS). webhook = needs HTTPS domain.
BOT_MODE=polling
WEBHOOK_URL=https://your-domain.example/webhook
WEBHOOK_SECRET=generate-a-long-random-string

# Database (Docker Compose service hostname is "postgres")
# Schema MUST be playstation_rental (used by Prisma + pg_dump backups)
POSTGRES_USER=nodexrent
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=nodexrent
DATABASE_URL=postgresql://nodexrent:CHANGE_ME_STRONG_PASSWORD@postgres:5432/nodexrent?schema=playstation_rental

# Server
PORT=3000
NODE_ENV=production

# Admins (Telegram numeric user IDs, comma-separated)
ADMIN_TELEGRAM_IDS=111111111
SUPER_ADMIN_TELEGRAM_IDS=111111111

# Business
RETURN_REMINDER_HOURS_BEFORE=2
COURIER_RESPONSE_TIMEOUT_MINUTES=10
ORDER_CONFIRM_WINDOW_HOURS=6
ORDER_PRIORITY_REMINDER_HOURS=2
DEFAULT_COMMISSION_PERCENT=0
LOCATION_UPDATE_COOLDOWN_MS=30000

# Rate limit (anti-spam)
RATE_LIMIT_WINDOW_MS=2000
RATE_LIMIT_MAX_REQUESTS=3
RATE_LIMIT_BLOCK_MS=60000
RATE_LIMIT_CLEANUP_MS=300000

# Startup (Docker entrypoint)
# Set RUN_SEED=true only on first deploy to seed console catalog / prices
RUN_SEED=false
