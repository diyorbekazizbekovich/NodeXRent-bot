generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ConsoleType {
  PS3
  PS4
  PS5
}

enum PlaystationStatus {
  AVAILABLE
  RESERVED
  RENTED
  MAINTENANCE
  MISSING_PARTS
  DEFECTIVE
}

enum InventoryItemType {
  CONSOLE
  JOYSTICK
  HDMI
  POWER
}

enum InventoryItemStatus {
  AVAILABLE
  RESERVED
  RENTED
  MAINTENANCE
}

enum ConditionGrade {
  IDEAL
  GOOD
  MINOR_ISSUE
  SERIOUS_ISSUE
}

enum OrderPhotoType {
  HANDOVER
  RETURN
}

enum CustomerRating {
  TRUSTED
  NORMAL
  RISKY
}

enum DiscountType {
  PERCENT
  FIXED
  LOYALTY
}

enum PaymentMethod {
  CASH
  CLICK
  CARD
}

enum CollateralType {
  ID_CARD
  PASSPORT
  NONE
}

enum ExtensionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  ADMIN_CONFIRMED
  COURIER_ASSIGNED
  ACCEPTED
  REJECTED
  ON_THE_WAY
  ARRIVED
  DELIVERED
  ACTIVE
  RETURN_REQUESTED
  RETURNED
  COMPLETED
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  PENDING
  FAILED
  REFUNDED
}

enum NotificationType {
  ORDER_CREATED
  ORDER_ACCEPTED
  ORDER_REJECTED
  COURIER_ON_WAY
  ORDER_DELIVERED
  RETURN_REMINDER
  ORDER_RETURNED
  ORDER_COMPLETED
  ORDER_CANCELLED
  COURIER_ASSIGNED
  ORDER_ARRIVED
  ADMIN_ORDER_ASSIGNED
  LOCATION_UPDATED
  PROMO
  ADVERTISEMENT
  ORDER_CONFIRM_READY
  ORDER_PRIORITY_REMINDER
  ORDER_START_REMINDER
}

model User {
  id             Int      @id @default(autoincrement())
  telegramId     BigInt   @unique
  username       String?
  fullName       String?
  phone          String?
  defaultAddress String?
  latitude       Float?
  longitude      Float?
  /// Foydalanuvchi interfeys tili: UZ | RU. null = hali tanlanmagan
  language         String?
  isBlocked        Boolean         @default(false)
  lastActivityAt   DateTime?
  customerRating   CustomerRating  @default(NORMAL)
  adminNotes       String?
  createdAt        DateTime        @default(now())
  orders           Order[]
  reviews          Review[]
  supportThread    SupportThread?

  @@index([lastActivityAt])
  @@map("users")
}

model Courier {
  id           Int           @id @default(autoincrement())
  telegramId   BigInt        @unique
  username     String?
  fullName     String?
  phone        String?
  region       String?
  latitude     Float?
  longitude    Float?
  isActive     Boolean       @default(true)
  rating       Decimal       @default(5) @db.Decimal(3, 2)
  createdAt    DateTime      @default(now())
  playstations Playstation[]
  orders       Order[]
  deliveredOrders Order[]    @relation("OrderDeliveredBy")
  orderRejections OrderCourierRejection[]

  @@map("couriers")
}

model Playstation {
  id           Int               @id @default(autoincrement())
  courierId    Int
  courier      Courier           @relation(fields: [courierId], references: [id])
  type         ConsoleType
  serialNumber String            @unique
  status       PlaystationStatus @default(AVAILABLE)
  accessories  Json?
  createdAt    DateTime          @default(now())
  orders       Order[]

  @@map("playstations")
}

model InventoryUnit {
  id            Int               @id @default(autoincrement())
  unitCode      String            @unique
  consoleType   ConsoleType
  status        PlaystationStatus @default(AVAILABLE)
  purchasedAt   DateTime?
  purchasePrice Decimal?          @db.Decimal(10, 2)
  lastServiceAt DateTime?
  adminNote     String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  orders        Order[]
  history       InventoryUnitHistory[]

  @@index([consoleType, status])
  @@map("inventory_units")
}

model InventoryUnitHistory {
  id              Int                @id @default(autoincrement())
  inventoryUnitId Int
  inventoryUnit   InventoryUnit      @relation(fields: [inventoryUnitId], references: [id], onDelete: Cascade)
  action          String
  fromStatus      PlaystationStatus?
  toStatus        PlaystationStatus?
  orderId         Int?
  note            String?
  actorType       String?
  actorId         Int?
  createdAt       DateTime           @default(now())

  @@index([inventoryUnitId, createdAt])
  @@map("inventory_unit_history")
}

model DeliveryZone {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  fee       Decimal  @db.Decimal(10, 2)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("delivery_zones")
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model AdminAuditLog {
  id              Int      @id @default(autoincrement())
  adminId         Int?
  adminTelegramId BigInt?
  module          String?
  action          String
  entityType      String?
  entityId        Int?
  beforeData      Json?
  afterData       Json?
  createdAt       DateTime @default(now())

  @@index([createdAt])
  @@index([module])
  @@map("admin_audit_logs")
}

model DatabaseBackup {
  id               Int      @id @default(autoincrement())
  filename         String
  filePath         String
  fileSize         BigInt?
  createdByAdminId Int?
  createdAt        DateTime @default(now())

  @@index([createdAt])
  @@map("database_backups")
}

model RentalExtension {
  id                Int             @id @default(autoincrement())
  orderId           Int
  order             Order           @relation(fields: [orderId], references: [id])
  extraHours        Int
  extraPrice        Decimal         @db.Decimal(10, 2)
  status            ExtensionStatus @default(PENDING)
  requestedAt       DateTime        @default(now())
  resolvedAt        DateTime?
  resolvedByAdminId Int?
  previousEnd       DateTime
  newEnd            DateTime?

  @@index([orderId, status])
  @@map("rental_extensions")
}

model ConsoleCatalog {
  id           Int           @id @default(autoincrement())
  code         String        @unique
  displayName  String
  isActive     Boolean       @default(true)
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  rentalPrices RentalPrice[]

  @@map("console_catalog")
}

model RentalPrice {
  id               Int            @id @default(autoincrement())
  consoleCatalogId Int
  consoleCatalog   ConsoleCatalog @relation(fields: [consoleCatalogId], references: [id], onDelete: Cascade)
  hours            Int
  price            Decimal        @db.Decimal(10, 2)
  currency         String         @default("UZS")
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  orders           Order[]

  @@unique([consoleCatalogId, hours])
  @@map("rental_prices")
}

model Promocode {
  id               Int          @id @default(autoincrement())
  code             String       @unique
  discountType     DiscountType @default(PERCENT)
  discountPercent  Int          @default(0)
  discountAmount   Decimal?     @db.Decimal(10, 2)
  loyaltyMinOrders Int?
  description      String?
  usageLimit       Int
  usedCount        Int          @default(0)
  minOrderAmount   Decimal?     @db.Decimal(10, 2)
  maxDiscountAmount Decimal?    @db.Decimal(10, 2)
  perUserLimit     Int          @default(1)
  expiresAt        DateTime
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  orders           Order[]

  @@map("promocodes")
}

model Order {
  id            Int          @id @default(autoincrement())
  userId        Int
  user          User         @relation(fields: [userId], references: [id])
  courierId     Int?
  courier       Courier?     @relation(fields: [courierId], references: [id])
  playstationId Int?
  playstation   Playstation? @relation(fields: [playstationId], references: [id])
  rentalPriceId Int
  rentalPrice   RentalPrice @relation(fields: [rentalPriceId], references: [id])
  promocodeId   Int?
  promocode     Promocode?   @relation(fields: [promocodeId], references: [id])

  consoleType   ConsoleType
  address       String
  latitude      Float?
  longitude     Float?
  startDatetime DateTime
  endDatetime   DateTime
  totalPrice    Decimal      @db.Decimal(10, 2)
  deliveryFee   Decimal      @default(0) @db.Decimal(10, 2)
  depositAmount Decimal      @default(0) @db.Decimal(10, 2)
  status        OrderStatus  @default(PENDING)
  inventoryUnitId Int?
  inventoryUnit InventoryUnit? @relation(fields: [inventoryUnitId], references: [id])
  acceptedAt    DateTime?
  assignedAt    DateTime?
  deliveryStartedAt DateTime?
  deliveryCompletedAt DateTime?
  assignedByAdmin Boolean    @default(false)

  /// Admin/kuryer tasdiqlagan vaqt (confirm window ichida)
  confirmedAt     DateTime?
  /// 2 soatlik priority eslatma yuborilganda
  isHighPriority  Boolean  @default(false)

  deliveryZoneCode String?

  /// Topshirish paytida olingan to'lov
  paymentReceived     Boolean        @default(false)
  paymentMethod       PaymentMethod?
  paymentReceivedAt   DateTime?
  finalPaidAmount     Decimal?       @db.Decimal(10, 2)

  /// Garov hujjati
  collateralType      CollateralType?
  collateralTaken     Boolean        @default(false)
  collateralReturned  Boolean        @default(false)

  deliveredByCourierId Int?
  deliveredByCourier   Courier?      @relation("OrderDeliveredBy", fields: [deliveredByCourierId], references: [id])

  /// Professional inventar topshirish
  consoleItemId   Int?
  consoleItem     InventoryItem? @relation("OrderConsoleItem", fields: [consoleItemId], references: [id])
  hdmiItemId      Int?
  hdmiItem        InventoryItem? @relation("OrderHdmiItem", fields: [hdmiItemId], references: [id])
  powerItemId     Int?
  powerItem       InventoryItem? @relation("OrderPowerItem", fields: [powerItemId], references: [id])

  returnCondition ConditionGrade?
  returnNote      String?
  returnedAt      DateTime?

  statusLogs       OrderStatusLog[]
  locationHistory  OrderLocationHistory[]
  review           Review?
  notifications    Notification[]
  payments         OrderPayment[]
  extensions       RentalExtension[]
  orderItems       OrderInventoryItem[]
  contract         RentalContract?
  photos           OrderPhoto[]
  reminderLogs     OrderReminderLog[]
  courierRejections OrderCourierRejection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([status, endDatetime])
  @@index([status, startDatetime])
  @@index([paymentReceived])
  @@index([isHighPriority])
  @@map("orders")
}

/// Idempotent reminder audit — server restart da qayta yuborilmasin
model OrderReminderLog {
  id        Int      @id @default(autoincrement())
  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  kind      String
  sentAt    DateTime @default(now())
  meta      Json?

  @@unique([orderId, kind])
  @@index([kind, sentAt])
  @@map("order_reminder_logs")
}

/// Courier declined an ADMIN_CONFIRMED order (re-queue pool exclusion)
model OrderCourierRejection {
  id        Int      @id @default(autoincrement())
  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  courierId Int
  courier   Courier  @relation(fields: [courierId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([orderId, courierId])
  @@index([orderId])
  @@map("order_courier_rejections")
}

/// Yetkazib berish manzili o'zgarishlari tarixi (faqat eng so'nggisi Order da active)
model OrderLocationHistory {
  id               Int      @id @default(autoincrement())
  orderId          Int
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId           Int
  previousLatitude Float?
  previousLongitude Float?
  previousAddress  String?
  newLatitude      Float?
  newLongitude     Float?
  newAddress       String?
  createdAt        DateTime @default(now())

  @@index([orderId, createdAt])
  @@index([userId, createdAt])
  @@map("order_location_history")
}

model InventoryItem {
  id              Int                 @id @default(autoincrement())
  itemType        InventoryItemType
  consoleType     ConsoleType?
  inventoryNumber String              @unique
  serialNumber    String              @unique
  condition       ConditionGrade      @default(GOOD)
  status          InventoryItemStatus @default(AVAILABLE)
  purchasedAt     DateTime?
  note            String?
  reservedOrderId Int?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  history         InventoryItemHistory[]
  orderLinks      OrderInventoryItem[]
  ordersAsConsole Order[] @relation("OrderConsoleItem")
  ordersAsHdmi    Order[] @relation("OrderHdmiItem")
  ordersAsPower   Order[] @relation("OrderPowerItem")

  @@index([itemType, status])
  @@index([consoleType, status])
  @@map("inventory_items")
}

model InventoryItemHistory {
  id              Int                  @id @default(autoincrement())
  inventoryItemId Int
  inventoryItem   InventoryItem        @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  action          String
  fromStatus      InventoryItemStatus?
  toStatus        InventoryItemStatus?
  orderId         Int?
  note            String?
  actorType       String?
  actorId         Int?
  createdAt       DateTime             @default(now())

  @@index([inventoryItemId])
  @@map("inventory_item_history")
}

model OrderInventoryItem {
  id              Int             @id @default(autoincrement())
  orderId         Int
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  inventoryItemId Int
  inventoryItem   InventoryItem   @relation(fields: [inventoryItemId], references: [id])
  role            InventoryItemType
  returnedAt      DateTime?
  returnCondition ConditionGrade?
  returnNote      String?
  createdAt       DateTime        @default(now())

  @@unique([orderId, inventoryItemId])
  @@index([orderId])
  @@map("order_inventory_items")
}

model RentalContract {
  id             Int      @id @default(autoincrement())
  orderId        Int      @unique
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  contractNumber String   @unique
  pdfPath        String?
  telegramFileId String?
  payload        Json?
  createdAt      DateTime @default(now())

  @@map("rental_contracts")
}

model OrderPhoto {
  id             Int           @id @default(autoincrement())
  orderId        Int
  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  photoType      OrderPhotoType
  filePath       String?
  telegramFileId String
  createdAt      DateTime      @default(now())

  @@index([orderId, photoType])
  @@map("order_photos")
}

model OrderStatusLog {
  id        Int         @id @default(autoincrement())
  orderId   Int
  order     Order       @relation(fields: [orderId], references: [id])
  status    OrderStatus
  actorType String?
  actorId   Int?
  note      String?
  changedAt DateTime    @default(now())

  @@map("order_status_logs")
}

model Review {
  id        Int      @id @default(autoincrement())
  orderId   Int      @unique
  order     Order    @relation(fields: [orderId], references: [id])
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@map("reviews")
}

model Notification {
  id            Int              @id @default(autoincrement())
  orderId       Int?
  order         Order?           @relation(fields: [orderId], references: [id])
  type          NotificationType
  recipientType String
  recipientId   Int
  isSent        Boolean          @default(false)
  sentAt        DateTime?
  createdAt     DateTime         @default(now())

  @@map("notifications")
}

model OrderPayment {
  id        Int           @id @default(autoincrement())
  orderId   Int
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount    Decimal       @db.Decimal(10, 2)
  method    PaymentMethod @default(CASH)
  status    PaymentStatus @default(UNPAID)
  paidAt    DateTime?
  note      String?
  createdAt DateTime      @default(now())

  @@index([orderId])
  @@index([status])
  @@map("order_payments")
}

model Admin {
  id         Int      @id @default(autoincrement())
  telegramId BigInt   @unique
  fullName   String?
  role       String   @default("admin")
  createdAt  DateTime @default(now())
  campaigns  AdCampaign[]
  supportMessages SupportMessage[]

  @@map("admins")
}

model AdCampaign {
  id             Int      @id @default(autoincrement())
  adminId        Int
  admin          Admin    @relation(fields: [adminId], references: [id])
  message        String
  mediaType      String   @default("text")
  payload        Json?
  recipientCount Int      @default(0)
  successCount   Int      @default(0)
  failCount      Int      @default(0)
  sentAt         DateTime @default(now())

  @@map("ad_campaigns")
}

enum SupportSenderType {
  ADMIN
  USER
}

enum SupportThreadStatus {
  OPEN
  CLOSED
}

/// Admin ↔ Mijoz qo'llab-quvvatlash chat (har bir mijoz uchun bitta thread)
model SupportThread {
  id            Int                 @id @default(autoincrement())
  userId        Int                 @unique
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  status        SupportThreadStatus @default(OPEN)
  lastMessageAt DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  messages      SupportMessage[]

  @@index([status])
  @@index([lastMessageAt])
  @@map("support_threads")
}

model SupportMessage {
  id                Int               @id @default(autoincrement())
  threadId          Int
  thread            SupportThread     @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderType        SupportSenderType
  senderUserId      Int?
  senderAdminId     Int?
  senderAdmin       Admin?            @relation(fields: [senderAdminId], references: [id])
  messageType       String
  text              String?
  caption           String?
  fileId            String?
  payload           Json?
  telegramMessageId BigInt?
  createdAt         DateTime          @default(now())

  @@index([threadId, createdAt])
  @@index([senderType])
  @@map("support_messages")
}
